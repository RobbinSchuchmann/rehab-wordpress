# Copy this file to .mcp.env (gitignored), then UNCOMMENT and set the token.
# Sourced by ~/.bashrc (before the interactivity guard) so tmux / claude
# subprocesses inherit it. Leaving it commented = no empty GH_TOKEN exported.
#
# GitHub personal access token for the gh CLI. Scopes: repo, read:org.
# Create one at: https://github.com/settings/tokens
# export GH_TOKEN=ghp_your_token_here
