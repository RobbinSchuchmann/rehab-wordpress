{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rehab/marquee",
  "version": "0.1.0",
  "title": "Marquee",
  "category": "rehab",
  "icon": "controls-forward",
  "description": "Auto-scrolling text strip — for slogans, accolades, or scrolling logos.",
  "keywords": [
    "marquee",
    "ticker",
    "scrolling"
  ],
  "textdomain": "rehab-blocks",
  "supports": {
    "html": false,
    "anchor": true,
    "align": [
      "full"
    ]
  },
  "attributes": {
    "background": {
      "type": "string",
      "default": "sage-mist",
      "enum": [
        "white",
        "cream",
        "sage-mist"
      ]
    },
    "speed": {
      "type": "number",
      "default": 30,
      "minimum": 10,
      "maximum": 120
    },
    "items": {
      "type": "array",
      "default": [
        "Voted #1 by The Thaiger",
        "Featured in Forbes",
        "Discovery Channel feature",
        "Conde Nast Traveler",
        "12-client luxury cap",
        "Lifetime aftercare guarantee"
      ],
      "items": {
        "type": "string"
      }
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}