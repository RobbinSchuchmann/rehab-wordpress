{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rehab/home-final-cta",
  "version": "0.1.0",
  "title": "Home: Final CTA",
  "category": "rehab",
  "icon": "megaphone",
  "description": "Homepage closing call-to-action — heading, body, button and helper line. Matches the hardcoded Final CTA section.",
  "keywords": [
    "homepage",
    "cta",
    "contact"
  ],
  "textdomain": "rehab-blocks",
  "supports": {
    "html": false,
    "anchor": true,
    "align": [
      "full"
    ]
  },
  "attributes": {
    "background": {
      "type": "string",
      "default": "sage-mist",
      "enum": [
        "white",
        "cream",
        "sage-mist"
      ]
    },
    "heading": {
      "type": "string",
      "default": ""
    },
    "body": {
      "type": "string",
      "default": ""
    },
    "buttonText": {
      "type": "string",
      "default": ""
    },
    "buttonUrl": {
      "type": "string",
      "default": ""
    },
    "helper": {
      "type": "string",
      "default": ""
    }
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}