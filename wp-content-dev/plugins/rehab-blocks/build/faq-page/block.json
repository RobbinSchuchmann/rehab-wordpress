{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rehab/faq-page",
  "version": "0.1.0",
  "title": "FAQ Page (categorised)",
  "category": "rehab",
  "icon": "editor-help",
  "description": "Full FAQ page body: sticky category navigation and categorised accordion groups.",
  "keywords": [
    "faq",
    "questions",
    "categories"
  ],
  "textdomain": "rehab-blocks",
  "supports": {
    "html": false,
    "anchor": true,
    "align": [
      "full"
    ]
  },
  "attributes": {
    "background": {
      "type": "string",
      "default": "cream",
      "enum": [
        "white",
        "cream",
        "sage-mist"
      ]
    },
    "navLabel": {
      "type": "string",
      "default": "Categories"
    },
    "categories": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object"
      }
    }
  },
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js",
  "render": "file:./render.php"
}