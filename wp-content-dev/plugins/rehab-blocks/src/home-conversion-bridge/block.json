{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rehab/home-conversion-bridge",
  "version": "0.1.0",
  "title": "Home: Conversion Bridge",
  "category": "rehab",
  "icon": "megaphone",
  "description": "Reusable homepage CTA band — heading, button and helper line. Matches the hardcoded Conversion Bridge section.",
  "keywords": ["homepage", "cta", "bridge", "conversion"],
  "textdomain": "rehab-blocks",
  "supports": { "html": false, "anchor": true, "align": ["full"] },
  "attributes": {
    "background": { "type": "string", "default": "sage-mist", "enum": ["white", "cream", "sage-mist"] },
    "heading": { "type": "string", "default": "" },
    "buttonText": { "type": "string", "default": "" },
    "buttonUrl": { "type": "string", "default": "" },
    "helper": { "type": "string", "default": "" }
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}
