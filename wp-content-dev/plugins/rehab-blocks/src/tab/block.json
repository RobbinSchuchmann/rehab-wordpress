{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rehab/tab",
  "version": "0.1.0",
  "title": "Tab",
  "category": "rehab",
  "icon": "tag",
  "description": "Single tab inside a Tabs block. Set the tab label, then add any blocks as content.",
  "parent": ["rehab/tabs"],
  "textdomain": "rehab-blocks",
  "supports": { "html": false, "inserter": true, "reusable": false },
  "attributes": {
    "label": { "type": "string", "default": "Tab" },
    "phaseNumber": { "type": "string", "default": "" }
  },
  "editorScript": "file:./index.js"
}
