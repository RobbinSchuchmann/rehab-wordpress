{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rehab/feature-split",
  "version": "0.1.0",
  "title": "Feature Split (rich)",
  "category": "rehab",
  "icon": "align-pull-left",
  "description": "Image + copy split with optional extras: modality chips, pull-quote, mini-stats and a gem-bullet list. Covers the About / founder-story / experience patterns on core pages.",
  "keywords": ["split", "about", "founder", "feature"],
  "textdomain": "rehab-blocks",
  "supports": { "html": false, "anchor": true, "align": ["full"] },
  "attributes": {
    "background": { "type": "string", "default": "cream", "enum": ["white", "cream", "sage-mist"] },
    "imageSide":  { "type": "string", "default": "left", "enum": ["left", "right"] },
    "imageUrl":   { "type": "string", "default": "" },
    "imageAlt":   { "type": "string", "default": "" },
    "eyebrow":    { "type": "string", "default": "" },
    "heading":    { "type": "string", "default": "" },
    "headingTag": { "type": "string", "default": "h2", "enum": ["h1", "h2"] },
    "body":       { "type": "string", "default": "" },
    "chips":      { "type": "array", "default": [], "items": { "type": "string" } },
    "quote":      { "type": "string", "default": "" },
    "quoteSrc":   { "type": "string", "default": "" },
    "stats":      { "type": "array", "default": [], "items": { "type": "object" } },
    "gemItems":   { "type": "array", "default": [], "items": { "type": "string" } },
    "footnote":   { "type": "string", "default": "" },
    "primaryText": { "type": "string", "default": "" },
    "primaryUrl":  { "type": "string", "default": "" },
    "phoneText":   { "type": "string", "default": "" },
    "phoneHref":   { "type": "string", "default": "tel:+61279082277" }
  },
  "editorScript": "file:./index.js",
  "style":        "file:./style-index.css",
  "render":       "file:./render.php"
}
