{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rehab/home-founder-vision",
  "version": "0.1.0",
  "title": "Home: Founder Vision",
  "category": "rehab",
  "icon": "format-quote",
  "description": "Homepage founder section — pull-quote, founder portrait, name, bio and an inspiration quote. Matches the hardcoded Founder Vision section.",
  "keywords": ["homepage", "founder", "quote", "vision"],
  "textdomain": "rehab-blocks",
  "supports": { "html": false, "anchor": true, "align": ["full"] },
  "attributes": {
    "quote": { "type": "string", "default": "" },
    "imageUrl": { "type": "string", "default": "" },
    "imageAlt": { "type": "string", "default": "" },
    "heading": { "type": "string", "default": "" },
    "bio": { "type": "string", "default": "" },
    "inspirationQuote": { "type": "string", "default": "" }
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}
