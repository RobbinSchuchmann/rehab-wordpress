{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rehab/video-reel",
  "version": "0.1.0",
  "title": "Video Testimonials (vertical reel)",
  "category": "rehab",
  "icon": "video-alt3",
  "description": "Row of vertical (9:16) video testimonial cards with quote captions and an aggregate Google-rating chip. Supports anonymous and family-perspective formats.",
  "keywords": [
    "video",
    "testimonials",
    "reel",
    "stories"
  ],
  "textdomain": "rehab-blocks",
  "supports": {
    "html": false,
    "anchor": true,
    "align": [
      "full"
    ]
  },
  "attributes": {
    "background": {
      "type": "string",
      "default": "cream"
    },
    "eyebrow": {
      "type": "string",
      "default": "Real stories"
    },
    "heading": {
      "type": "string",
      "default": "Recovery, in their own words"
    },
    "showRating": {
      "type": "boolean",
      "default": true
    },
    "ratingScore": {
      "type": "string",
      "default": "4.9"
    },
    "ratingText": {
      "type": "string",
      "default": "· 48 Google reviews"
    },
    "items": {
      "type": "array",
      "default": [
        {
          "name": "",
          "duration": "0:53",
          "tone": "1",
          "quote": "\"This is why I could not cry for so long.\"",
          "who": "",
          "videoUrl": "https://www.youtube.com/shorts/731wlg_mK34?feature=share",
          "posterUrl": ""
        },
        {
          "name": "",
          "duration": "0:50",
          "tone": "4",
          "quote": "\"This is why I am proud to be a recovering addict.\"",
          "who": "",
          "videoUrl": "https://www.youtube.com/shorts/aV-5dFPwKsE?feature=share",
          "posterUrl": ""
        },
        {
          "name": "",
          "duration": "0:44",
          "tone": "3",
          "quote": "\"This is how I ended up in rehab with an addiction.\"",
          "who": "",
          "videoUrl": "https://www.youtube.com/shorts/KVDVpTtRUPg?feature=share",
          "posterUrl": ""
        },
        {
          "name": "",
          "duration": "0:52",
          "tone": "2",
          "quote": "\"This is why I went to rehab.\"",
          "who": "",
          "videoUrl": "https://www.youtube.com/shorts/xxk-PAqWPQk?feature=share",
          "posterUrl": ""
        }
      ]
    }
  },
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js",
  "render": "file:./render.php"
}
