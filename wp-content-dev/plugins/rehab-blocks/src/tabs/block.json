{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rehab/tabs",
  "version": "0.1.0",
  "title": "Tabs",
  "category": "rehab",
  "icon": "list-view",
  "description": "Tabbed content. Add as many tabs as you need; each tab can hold any inner blocks.",
  "keywords": ["tabs", "tabbed", "switcher"],
  "textdomain": "rehab-blocks",
  "supports": { "html": false, "anchor": true, "align": ["full"] },
  "attributes": {
    "background": { "type": "string", "default": "white", "enum": ["white", "cream", "sage-mist"] },
    "heading": { "type": "string", "default": "" }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js"
}
