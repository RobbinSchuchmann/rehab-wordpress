{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rehab/map",
  "version": "0.1.0",
  "title": "Map",
  "category": "rehab",
  "icon": "location",
  "description": "Location map (Google Maps embed) with optional heading and address details.",
  "keywords": ["map", "location", "address", "google maps"],
  "textdomain": "rehab-blocks",
  "supports": { "html": false, "anchor": true, "align": ["full"] },
  "attributes": {
    "background": { "type": "string", "default": "white", "enum": ["white", "cream", "sage-mist"] },
    "heading": { "type": "string", "default": "Find us" },
    "address": { "type": "string", "default": "The Diamond Rehab Thailand, 8 Moo 14, Soi Mon Mai Hin Lek Fai, Hua Hin District, Prachuap Khiri Khan 77110, Thailand" },
    "embedUrl": {
      "type": "string",
      "default": "https://www.google.com/maps?q=12.5737202,99.9074386&z=16&output=embed"
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}
