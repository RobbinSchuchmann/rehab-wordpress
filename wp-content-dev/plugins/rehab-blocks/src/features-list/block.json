{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rehab/features-list",
  "version": "0.1.0",
  "title": "Features List",
  "category": "rehab",
  "icon": "list-view",
  "description": "Icon + title + body grid. Use for service highlights, key features, value propositions.",
  "keywords": ["features", "list", "icons"],
  "textdomain": "rehab-blocks",
  "supports": { "html": false, "anchor": true, "align": ["full"] },
  "attributes": {
    "background": { "type": "string", "default": "white", "enum": ["white", "cream", "sage-mist"] },
    "columns": { "type": "number", "default": 3, "enum": [2, 3, 4] },
    "heading": { "type": "string", "default": "" },
    "subheading": { "type": "string", "default": "" }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}
