{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rehab/stat-band",
  "version": "0.1.0",
  "title": "Stat Band (light)",
  "category": "rehab",
  "icon": "chart-bar",
  "description": "Light warm-cream band with up to four large serif statistics separated by sage hairlines.",
  "keywords": ["stats", "numbers", "band", "trust"],
  "textdomain": "rehab-blocks",
  "supports": { "html": false, "anchor": true, "align": ["full"] },
  "attributes": {
    "stat1Num":   { "type": "string", "default": "12" },
    "stat1Label": { "type": "string", "default": "Client cap, always" },
    "stat2Num":   { "type": "string", "default": "4:1" },
    "stat2Label": { "type": "string", "default": "Staff-to-client ratio" },
    "stat3Num":   { "type": "string", "default": "50+" },
    "stat3Label": { "type": "string", "default": "Specialist staff" },
    "stat4Num":   { "type": "string", "default": "28" },
    "stat4Label": { "type": "string", "default": "Day core program" }
  },
  "editorScript": "file:./index.js",
  "style":        "file:./style-index.css",
  "render":       "file:./render.php"
}
