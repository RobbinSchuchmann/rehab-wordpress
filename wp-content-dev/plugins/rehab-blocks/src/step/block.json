{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rehab/step",
  "version": "0.1.0",
  "title": "Step",
  "category": "rehab",
  "icon": "list-view",
  "description": "A single step in a Steps block. Auto-numbered.",
  "parent": ["rehab/steps"],
  "textdomain": "rehab-blocks",
  "supports": { "html": false, "inserter": true, "reusable": false },
  "attributes": {
    "title": { "type": "string", "default": "Step title" },
    "body": { "type": "string", "default": "Describe what happens in this step." }
  },
  "editorScript": "file:./index.js"
}
